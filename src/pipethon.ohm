// pipethon.ohm — The official Pipethon grammar
//
// Pipethon is a pipe-oriented, pattern-matching language designed for AI workflows.
// Key design decisions encoded here:
//   - Pipeline operator |> chains transformations
//   - Pattern blocks { pattern => expr } dispatch on type/shape/value
//   - null/none is ONLY valid in explicitly optional (Type?) contexts
//   - Unannotated variables are Any (non-nullable)
//   - llm() is a first-class pipe stage returning String?
//   - ?? is the null-coalescing operator (only valid on optional values)

Pipethon {

  // ── Top Level ───────────────────────────────────────────────────────────────

  Program = Statement+

  Statement = LetDecl
            | PipelineDecl
            | ExprStmt

  // let x = expr;
  // let x: String? = none;
  LetDecl = let id (":" TypeAnnot)? "=" Pipeline ";"

  // pipeline name = stage |> stage ...;
  // pipeline name: [Int] -> [Int] = stage |> stage ...;
  PipelineDecl = pipeline id (":" PipelineType)? "=" Pipeline ";"

  ExprStmt = Pipeline ";"

  // ── Pipelines ───────────────────────────────────────────────────────────────

  // A pipeline is an expression optionally followed by one or more |> stages.
  // With no stages, it degenerates to a plain expression.
  Pipeline = Expr ("|>" PipeStage)*

  PipeStage = llm "(" NonemptyListOf<LLMArg, ","> ")"  -- llm
            | id PatternBlock                            -- namedStage
            | PatternBlock                               -- anonStage
            | id "(" ListOf<Expr, ","> ")"              -- call
            | id                                        -- ref

  // llm(model: "claude", prompt: "...", format: json)
  LLMArg = id ":" (strlit | id)

  // ── Pattern Blocks ──────────────────────────────────────────────────────────

  PatternBlock = "{" MatchArm+ "}"

  // pattern [if guard] => body
  MatchArm = Pattern ("if" Expr)? "=>" ArmBody

  // drop removes the item; any expression is otherwise valid
  ArmBody = drop | Expr

  // ── Patterns ────────────────────────────────────────────────────────────────

  Pattern = some "(" id ")"                               -- some
          | none                                          -- none
          | typePat "(" id ")"                            -- typed
          | "[" "]"                                       -- emptyList
          | "[" id "]"                                    -- singleList
          | "[" id "," "..." id "]"                       -- headTail
          | "{" NonemptyListOf<FieldPat, ","> "}"         -- object
          | strlit                                        -- strLit
          | floatlit                                      -- floatLit
          | intlit                                        -- intLit
          | boollit                                       -- boolLit
          | "_"                                           -- wildcard

  // The five matchable runtime types
  typePat = "int" ~alnum
          | "float" ~alnum
          | "string" ~alnum
          | "bool" ~alnum
          | "list" ~alnum

  // { name: n, age: a }  or shorthand  { name, age }
  FieldPat = id ":" id   -- bound
           | id           -- shorthand

  // ── Type Annotations ────────────────────────────────────────────────────────

  // String?  vs  String
  TypeAnnot = PrimType "?"   -- optional
            | PrimType        -- required

  // Valid primitive type names
  PrimType = "Int" | "Float" | "String" | "Bool" | "List" | "Any"

  // Used in named pipeline declarations: [Int] -> [Int]
  PipelineType = TypeAnnot "->" TypeAnnot

  // ── Expressions (precedence: lowest at top, highest at bottom) ───────────
  //
  // ?? (null coalesce) — lowest, only valid on optional-typed left operand
  // ||  &&  == !=  < <= > >=  + -  * / %  unary  method calls  primary

  Expr  = Expr "??" Expr0   -- coalesce
        | Expr0

  Expr0 = Expr0 "||" Expr1  -- or
        | Expr1

  Expr1 = Expr1 "&&" Expr2  -- and
        | Expr2

  Expr2 = Expr2 ("==" | "!=") Expr3   -- eq
        | Expr3

  Expr3 = Expr3 ("<=" | ">=" | "<" | ">") Expr4  -- compare
        | Expr4

  Expr4 = Expr4 ("+" | "-") Expr5   -- add
        | Expr5

  Expr5 = Expr5 ("*" | "/" | "%") Expr6  -- mul
        | Expr6

  Expr6 = "-" Expr6   -- negate
        | "!" Expr6   -- not
        | Expr7

  // Method calls and member access (highest binary precedence)
  Expr7 = Expr7 "." id "(" ListOf<Expr, ","> ")"  -- methodCall
        | Expr7 "." id                              -- member
        | Primary

  Primary = "(" Expr ")"                                  -- parens
          | "[" ListOf<Expr, ","> "]"                     -- list
          | "{" NonemptyListOf<ObjField, ","> "}"         -- object
          | llm "(" NonemptyListOf<LLMArg, ","> ")"       -- llm
          | floatlit
          | intlit
          | strlit
          | boollit
          | none                                          -- none
          | id "(" ListOf<Expr, ","> ")"                 -- call
          | id                                           -- id

  ObjField = id ":" Expr

  // ── Lexical Rules ────────────────────────────────────────────────────────────

  intlit   = digit+
  floatlit = digit+ "." digit+ (("e" | "E") ("+" | "-")? digit+)?
  boollit  = ("true" | "false") ~alnum

  // Strings support \n \t \\ \" escape sequences.
  // Note: {input} interpolation in llm prompts is treated as literal text
  // by the parser; the analyzer validates that interpolated names are in scope.
  strlit  = "\"" strChar* "\""
  strChar = ~"\"" ~"\n" ~"\\" any
          | "\\" ("n" | "t" | "\\" | "\"")  -- escape

  // ── Keywords ────────────────────────────────────────────────────────────────
  // Every keyword uses a ~alnum trailing guard to prevent partial matches
  // (e.g., preventing "letter" from matching the "let" keyword).

  let      = "let"      ~alnum
  pipeline = "pipeline" ~alnum
  some     = "some"     ~alnum
  none     = "none"     ~alnum
  drop     = "drop"     ~alnum
  llm      = "llm"      ~alnum
  if       = "if"       ~alnum

  keyword = let | pipeline | some | none | drop | llm | if
          | "int"    ~alnum
          | "float"  ~alnum
          | "string" ~alnum
          | "bool"   ~alnum
          | "list"   ~alnum
          | "true"   ~alnum
          | "false"  ~alnum

  // Identifiers may not shadow keywords.
  // Underscores are allowed after the first character.
  id = ~keyword letter (alnum | "_")*

  // Extend whitespace to include both comment styles.
  space += "//" (~"\n" any)*        -- lineComment
         | "/*" (~"*/" any)* "*/"   -- blockComment
}